@using TransportationMongoDB.Dtos.QuestionDtos
@model CreateQuestionDto
@{
    ViewData["Title"] = "CreateQuestion";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap');

    :root {
        --primary: #00F0FF;
        --primary-dark: #00D4E6;
        --secondary: #FF2E97;
        --accent: #FFEB3B;
        --dark: #0A0E27;
        --dark-light: #1A1F3A;
        --bg: #0F1429;
        --card-bg: #161B33;
        --text: #E8F1FF;
        --text-muted: #8B92B0;
        --border: #2A3150;
        --shadow-sm: 0 4px 16px rgba(0, 240, 255, 0.1);
        --shadow-md: 0 8px 32px rgba(0, 240, 255, 0.15);
        --shadow-lg: 0 16px 48px rgba(0, 240, 255, 0.2);
        --glow: 0 0 20px rgba(0, 240, 255, 0.5);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Space Grotesk', sans-serif;
        background: var(--bg);
        color: var(--text);
        position: relative;
        overflow-x: hidden;
    }

    /* Retro Background */
    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background:
            radial-gradient(circle at 20% 80%, rgba(0, 240, 255, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(255, 46, 151, 0.1) 0%, transparent 50%),
            linear-gradient(180deg, transparent 0%, rgba(0, 240, 255, 0.02) 100%);
        z-index: 0;
        pointer-events: none;
    }

    /* Animated Grid */
    body::after {
        content: '';
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 300px;
        background-image:
            linear-gradient(0deg, transparent 24%, rgba(0, 240, 255, 0.1) 25%, rgba(0, 240, 255, 0.1) 26%, transparent 27%, transparent 74%, rgba(0, 240, 255, 0.1) 75%, rgba(0, 240, 255, 0.1) 76%, transparent 77%, transparent),
            linear-gradient(90deg, transparent 24%, rgba(0, 240, 255, 0.1) 25%, rgba(0, 240, 255, 0.1) 26%, transparent 27%, transparent 74%, rgba(0, 240, 255, 0.1) 75%, rgba(0, 240, 255, 0.1) 76%, transparent 77%, transparent);
        background-size: 50px 50px;
        transform: perspective(500px) rotateX(60deg);
        z-index: 0;
        pointer-events: none;
        opacity: 0.5;
    }

    .question-create-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 64px 32px;
        position: relative;
        z-index: 1;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Retro Header */
    .page-header {
        text-align: center;
        margin-bottom: 64px;
        position: relative;
    }

    .glitch-wrapper {
        position: relative;
        display: inline-block;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 64px;
        font-weight: 900;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 4px;
        margin-bottom: 20px;
        text-shadow:
            0 0 10px rgba(0, 240, 255, 0.8),
            0 0 20px rgba(0, 240, 255, 0.6),
            0 0 30px rgba(0, 240, 255, 0.4);
        animation: glow 2s ease-in-out infinite alternate;
    }

    @@keyframes glow {
        from { text-shadow: 0 0 10px rgba(0, 240, 255, 0.8), 0 0 20px rgba(0, 240, 255, 0.6); }
        to { text-shadow: 0 0 20px rgba(0, 240, 255, 1), 0 0 30px rgba(0, 240, 255, 0.8), 0 0 40px rgba(0, 240, 255, 0.6); }
    }

    .page-subtitle {
        font-size: 18px;
        color: var(--text-muted);
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .accent-line {
        width: 200px;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
        margin: 24px auto 0;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 0.6; }
        50% { opacity: 1; }
    }

    /* Split Layout */
    .split-layout {
        display: grid;
        grid-template-columns: 1fr 420px;
        gap: 48px;
        animation: slideUp 0.8s ease-out 0.2s both;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Form Column */
    .form-column {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .form-card {
        background: var(--card-bg);
        border: 2px solid var(--primary);
        border-radius: 16px;
        padding: 40px;
        position: relative;
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .form-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(0, 240, 255, 0.03), transparent);
        pointer-events: none;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--border);
    }

    .card-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--glow);
        animation: rotate 10s linear infinite;
    }

    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .card-icon svg {
        width: 28px;
        height: 28px;
        color: var(--dark);
    }

    .card-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    /* Form Groups */
    .form-group {
        margin-bottom: 28px;
        animation: fadeInUp 0.7s ease-out both;
    }

    .form-group:nth-child(1) { animation-delay: 0.1s; }
    .form-group:nth-child(2) { animation-delay: 0.15s; }
    .form-group:nth-child(3) { animation-delay: 0.2s; }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(25px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .label-required {
        color: var(--secondary);
        margin-left: 4px;
    }

    .form-input,
    .form-textarea {
        width: 100%;
        padding: 16px 20px;
        font-size: 15px;
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 500;
        border: 2px solid var(--border);
        border-radius: 12px;
        background: var(--dark-light);
        color: var(--text);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        outline: none;
    }

    .form-input:focus,
    .form-textarea:focus {
        border-color: var(--primary);
        background: var(--dark);
        box-shadow: 0 0 0 4px rgba(0, 240, 255, 0.1), var(--glow);
        transform: translateY(-2px);
    }

    .form-textarea {
        resize: vertical;
        min-height: 180px;
        line-height: 1.8;
    }

    .input-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
    }

    .input-hint {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 600;
    }

    .input-hint svg {
        width: 16px;
        height: 16px;
        color: var(--primary);
    }

    .char-counter {
        font-family: 'Orbitron', monospace;
        font-size: 12px;
        color: var(--primary);
        font-weight: 700;
    }

    /* Status Toggle */
    .status-wrapper {
        background: linear-gradient(135deg, rgba(0, 240, 255, 0.1), rgba(255, 46, 151, 0.1));
        border: 2px solid var(--primary);
        border-radius: 12px;
        padding: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .status-wrapper::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(45deg, transparent, rgba(0, 240, 255, 0.1), transparent);
        animation: shimmer 3s infinite;
    }

    @@keyframes shimmer {
        0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
        100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
    }

    .status-label {
        position: relative;
        z-index: 1;
    }

    .status-label h4 {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .status-label p {
        font-size: 13px;
        color: var(--text-muted);
        font-weight: 600;
    }

    .toggle-switch {
        position: relative;
        width: 68px;
        height: 36px;
        z-index: 1;
    }

    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--border);
        border-radius: 34px;
        transition: 0.4s;
        border: 2px solid var(--primary);
    }

    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 26px;
        width: 26px;
        left: 3px;
        bottom: 3px;
        background: var(--dark);
        border-radius: 50%;
        transition: 0.4s;
        box-shadow: 0 0 10px rgba(0, 240, 255, 0.5);
    }

    .toggle-switch input:checked + .toggle-slider {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        box-shadow: var(--glow);
    }

    .toggle-switch input:checked + .toggle-slider:before {
        transform: translateX(32px);
        box-shadow: 0 0 20px rgba(0, 240, 255, 1);
    }

    /* Preview Column */
    .preview-column {
        position: sticky;
        top: 32px;
        height: fit-content;
    }

    .preview-wrapper {
        background: var(--card-bg);
        border: 2px solid var(--secondary);
        border-radius: 16px;
        padding: 48px;
        position: relative;
        box-shadow: var(--shadow-lg);
        animation: slideUp 0.8s ease-out 0.3s both;
        overflow: hidden;
    }

    .preview-wrapper::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 46, 151, 0.1) 0%, transparent 70%);
        animation: float 8s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(20px, 20px) rotate(180deg); }
    }

    .preview-label {
        font-family: 'Orbitron', sans-serif;
        font-size: 12px;
        font-weight: 700;
        color: var(--secondary);
        margin-bottom: 32px;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .faq-preview {
        background: var(--dark-light);
        border: 2px solid var(--primary);
        border-radius: 12px;
        padding: 28px;
        position: relative;
        z-index: 1;
    }

    .faq-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        box-shadow: var(--glow);
    }

    .faq-icon svg {
        width: 32px;
        height: 32px;
        color: var(--dark);
    }

    .preview-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 16px;
        line-height: 1.4;
        text-transform: uppercase;
    }

    .preview-description {
        font-size: 15px;
        color: var(--text-muted);
        line-height: 1.8;
        font-weight: 500;
    }

    /* Action Buttons */
    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 40px;
    }

    .btn {
        flex: 1;
        padding: 18px 32px;
        font-size: 14px;
        font-weight: 700;
        border-radius: 12px;
        border: 2px solid;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Orbitron', sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 2px;
        position: relative;
        overflow: hidden;
    }

    .btn::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn:hover::before {
        width: 400px;
        height: 400px;
    }

    .btn span,
    .btn svg {
        position: relative;
        z-index: 1;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: var(--dark);
        border-color: var(--primary);
        box-shadow: var(--glow);
    }

    .btn-primary:hover {
        transform: translateY(-4px);
        box-shadow: 0 0 30px rgba(0, 240, 255, 0.8);
    }

    .btn-secondary {
        background: transparent;
        color: var(--text);
        border-color: var(--border);
    }

    .btn-secondary:hover {
        background: var(--dark-light);
        border-color: var(--primary);
    }

    /* Info Box */
    .info-box {
        background: linear-gradient(135deg, rgba(255, 235, 59, 0.1), rgba(255, 235, 59, 0.05));
        border: 2px solid var(--accent);
        border-radius: 12px;
        padding: 24px;
        position: relative;
        overflow: hidden;
    }

    .info-box::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 235, 59, 0.1), transparent);
        animation: slide 3s infinite;
    }

    @@keyframes slide {
        0% { left: -100%; }
        100% { left: 100%; }
    }

    .info-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 16px;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
    }

    .info-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
        position: relative;
        z-index: 1;
    }

    .info-list li {
        display: flex;
        align-items: start;
        gap: 12px;
        font-size: 14px;
        color: var(--text);
        line-height: 1.7;
        font-weight: 500;
    }

    .info-list li::before {
        content: '▸';
        color: var(--accent);
        font-size: 16px;
        flex-shrink: 0;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .split-layout {
            grid-template-columns: 1fr;
        }

        .preview-column {
            position: relative;
            top: 0;
        }
    }

    @@media (max-width: 768px) {
        .question-create-container {
            padding: 48px 20px;
        }

        .page-title {
            font-size: 48px;
        }

        .form-card,
        .preview-wrapper {
            padding: 28px 24px;
        }

        .form-actions {
            flex-direction: column-reverse;
        }
    }
</style>

<div class="question-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="glitch-wrapper">
            <h1 class="page-title">Sık Sorulan Sorular</h1>
        </div>
        <p class="page-subtitle">Yeni Soru Ekle</p>
        <div class="accent-line"></div>
    </div>

    <!-- Split Layout -->
    <form method="post" id="questionForm">
        <div class="split-layout">
            <!-- Form Column -->
            <div class="form-column">
                <!-- Main Card -->
                <div class="form-card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h2 class="card-title">Soru Bilgileri</h2>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Title">
                            Soru Başlığı <span class="label-required">*</span>
                        </label>
                        <input type="text"
                               class="form-input"
                               asp-for="Title"
                               id="titleInput"
                               placeholder="Örn: Kargo teslimat süresi ne kadar?"
                               maxlength="200"
                               required />
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Net ve anlaşılır soru yazın
                            </div>
                            <span class="char-counter">
                                <span id="titleCounter">0</span>/200
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Description">
                            Cevap <span class="label-required">*</span>
                        </label>
                        <textarea class="form-textarea"
                                  asp-for="Description"
                                  id="descriptionInput"
                                  placeholder="Sorunun detaylı cevabını buraya yazın..."
                                  maxlength="1000"
                                  required></textarea>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Kapsamlı ve yardımcı bir cevap verin
                            </div>
                            <span class="char-counter">
                                <span id="descCounter">0</span>/1000
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="status-wrapper">
                            <div class="status-label">
                                <h4>Yayın Durumu</h4>
                                <p>Soruyu anında yayınla</p>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" asp-for="Status" id="statusToggle" checked />
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Info Box -->
                <div class="info-box">
                    <h3 class="info-title">⚡ Pro İpuçları</h3>
                    <ul class="info-list">
                        <li>Müşterilerinizin en çok sorduğu soruları ekleyin</li>
                        <li>Cevaplar net, kısa ve anlaşılır olmalı</li>
                        <li>Teknik terimleri açıklayarak kullanın</li>
                        <li>Sorular soru işareti ile bitmelidir</li>
                    </ul>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a href="/Question/QuestionList/" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span>İptal</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>Kaydet</span>
                    </button>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="preview-column">
                <div class="preview-wrapper">
                    <div class="preview-label">◉ Canlı Önizleme ◉</div>
                    <div class="faq-preview">
                        <div class="faq-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h3 class="preview-title" id="previewTitle">Soru Başlığı?</h3>
                        <p class="preview-description" id="previewDescription">Sorunun cevabı burada görünecek...</p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    // Form inputs
    const titleInput = document.getElementById('titleInput');
    const descriptionInput = document.getElementById('descriptionInput');
    
    // Counters
    const titleCounter = document.getElementById('titleCounter');
    const descCounter = document.getElementById('descCounter');
    
    // Preview elements
    const previewTitle = document.getElementById('previewTitle');
    const previewDescription = document.getElementById('previewDescription');

    // Update counters and preview
    titleInput.addEventListener('input', (e) => {
        titleCounter.textContent = e.target.value.length;
        previewTitle.textContent = e.target.value || 'Soru Başlığı?';
    });

    descriptionInput.addEventListener('input', (e) => {
        descCounter.textContent = e.target.value.length;
        previewDescription.textContent = e.target.value || 'Sorunun cevabı burada görünecek...';
    });

    // Form validation
    const form = document.getElementById('questionForm');
    form.addEventListener('submit', (e) => {
        const title = titleInput.value.trim();
        const description = descriptionInput.value.trim();

        if (!title || !description) {
            e.preventDefault();
            alert('Lütfen tüm zorunlu alanları doldurun!');
            
            if (!title) titleInput.style.borderColor = 'var(--secondary)';
            if (!description) descriptionInput.style.borderColor = 'var(--secondary)';

            setTimeout(() => {
                titleInput.style.borderColor = '';
                descriptionInput.style.borderColor = '';
            }, 2000);
        }
    });
</script>
