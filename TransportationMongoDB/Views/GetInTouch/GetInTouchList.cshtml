@model List<ResultGetInTouchDto>
@{
    ViewData["Title"] = "İletişim Bölümü Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Courier+Prime:wght@400;700&family=Work+Sans:wght@400;500;600;700;800&display=swap');

    :root {
        --primary: #FF4757;
        --primary-dark: #EE2F42;
        --dark: #2C3E50;
        --dark-deep: #1A252F;
        --accent: #FFD93D;
        --bg: #ECF0F1;
        --card-bg: #FFFFFF;
        --text: #2C3E50;
        --text-muted: #7F8C8D;
        --border: #BDC3C7;
        --success: #27AE60;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Work Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
    }

    /* Grid Background */
    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: 
            linear-gradient(rgba(44, 62, 80, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(44, 62, 80, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        z-index: 0;
        pointer-events: none;
    }

    .getintouch-list-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 60px 40px;
        position: relative;
        z-index: 1;
        animation: fadeIn 0.7s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 50px;
        gap: 32px;
        flex-wrap: wrap;
    }

    .header-left {
        flex: 1;
        min-width: 300px;
    }

    .header-tag {
        display: inline-block;
        padding: 8px 20px;
        background: var(--dark);
        color: var(--accent);
        font-family: 'Courier Prime', monospace;
        font-weight: 700;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 24px;
    }

    .header-tag::before {
        content: '//';
        margin-right: 8px;
        color: var(--primary);
    }

    .page-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 64px;
        font-weight: 400;
        color: var(--dark);
        line-height: 0.9;
        margin-bottom: 16px;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .page-title::after {
        content: '';
        display: block;
        width: 180px;
        height: 5px;
        background: var(--primary);
        margin-top: 12px;
    }

    .page-subtitle {
        font-size: 16px;
        color: var(--text-muted);
        font-weight: 500;
        margin-top: 16px;
    }

    .header-actions {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn {
        padding: 16px 28px;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 18px;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-primary {
        background: var(--primary);
        color: white;
        border: 3px solid var(--primary);
    }

    .btn-primary:hover {
        background: var(--primary-dark);
        border-color: var(--primary-dark);
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(255, 71, 87, 0.3);
    }

    .btn-icon {
        background: transparent;
        color: var(--dark);
        width: 52px;
        height: 52px;
        padding: 0;
        justify-content: center;
        border: 3px solid var(--dark);
    }

    .btn-icon:hover {
        background: var(--dark);
        color: white;
    }

    /* Stats Terminal */
    .stats-terminal {
        background: var(--dark-deep);
        border: 4px solid var(--dark);
        padding: 32px 40px;
        margin-bottom: 48px;
        position: relative;
        animation: slideUp 0.7s ease-out 0.1s both;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .stats-terminal::before {
        content: '// İSTATİSTİKLER';
        position: absolute;
        top: -14px;
        left: 20px;
        background: var(--accent);
        color: var(--dark);
        padding: 4px 16px;
        font-family: 'Courier Prime', monospace;
        font-weight: 700;
        font-size: 11px;
        letter-spacing: 1px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 40px;
    }

    .stat-item {
        text-align: center;
        padding: 0 20px;
        border-right: 2px solid rgba(255, 255, 255, 0.1);
    }

    .stat-item:last-child {
        border-right: none;
    }

    .stat-label {
        font-family: 'Courier Prime', monospace;
        font-size: 11px;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    .stat-value {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 56px;
        color: white;
        line-height: 1;
    }

    /* Control Bar */
    .control-bar {
        background: var(--card-bg);
        border: 3px solid var(--dark);
        padding: 20px 28px;
        margin-bottom: 40px;
        display: flex;
        gap: 20px;
        align-items: center;
        flex-wrap: wrap;
        animation: slideUp 0.7s ease-out 0.2s both;
    }

    .search-box {
        flex: 1;
        min-width: 320px;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 14px 20px 14px 50px;
        border: 3px solid var(--border);
        font-size: 15px;
        font-family: 'Work Sans', sans-serif;
        font-weight: 600;
        background: var(--bg);
        color: var(--text);
        transition: all 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--primary);
        background: white;
        transform: translateX(4px);
    }

    .search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        color: var(--text-muted);
        pointer-events: none;
    }

    .filter-toggle {
        display: flex;
        gap: 8px;
        background: var(--bg);
        padding: 6px;
        border: 3px solid var(--dark);
    }

    .filter-btn {
        padding: 10px 20px;
        font-family: 'Courier Prime', monospace;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: none;
        background: transparent;
        color: var(--text);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .filter-btn:hover {
        background: var(--dark);
        color: white;
    }

    .filter-btn.active {
        background: var(--primary);
        color: white;
    }

    /* Content Grid */
    .sections-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(500px, 1fr));
        gap: 40px;
        animation: slideUp 0.7s ease-out 0.3s both;
    }

    .section-card {
        background: var(--card-bg);
        border: 4px solid var(--dark);
        position: relative;
        transition: all 0.4s ease;
        animation: fadeInScale 0.6s ease-out both;
    }

    @@keyframes fadeInScale {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }

    .section-card::before {
        content: attr(data-id);
        position: absolute;
        top: -16px;
        left: -16px;
        width: 56px;
        height: 56px;
        background: var(--accent);
        border: 4px solid var(--dark);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 24px;
        color: var(--dark);
        z-index: 1;
    }

    .section-card:hover {
        transform: translate(6px, -6px);
        box-shadow: -6px 6px 0 var(--dark);
    }

    .card-header {
        background: var(--dark-deep);
        padding: 28px 32px;
        border-bottom: 3px solid var(--dark);
    }

    .card-badge {
        display: inline-block;
        padding: 6px 14px;
        background: var(--primary);
        color: white;
        font-family: 'Courier Prime', monospace;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 16px;
    }

    .card-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 36px;
        color: white;
        line-height: 1.1;
        margin-bottom: 16px;
        text-transform: uppercase;
    }

    .card-description {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-body {
        padding: 32px;
    }

    .features-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 28px;
    }

    .feature-item {
        border-left: 4px solid var(--accent);
        padding-left: 16px;
    }

    .feature-item-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 18px;
        color: var(--dark);
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .feature-item-desc {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.5;
    }

    .card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 24px;
        margin-top: 24px;
        border-top: 3px solid var(--border);
    }

    .meta-info {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .meta-item {
        font-family: 'Courier Prime', monospace;
        font-size: 11px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .status-badge {
        padding: 6px 14px;
        font-family: 'Courier Prime', monospace;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: 2px solid;
    }

    .status-badge.active {
        background: var(--success);
        color: white;
        border-color: var(--success);
    }

    .status-badge.inactive {
        background: transparent;
        color: var(--text-muted);
        border-color: var(--text-muted);
    }

    .card-actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
    }

    .action-btn {
        flex: 1;
        padding: 14px 20px;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 16px;
        letter-spacing: 1px;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .action-btn.edit {
        background: transparent;
        color: var(--dark);
        border: 3px solid var(--dark);
    }

    .action-btn.edit:hover {
        background: var(--dark);
        color: white;
    }

    .action-btn.delete {
        background: transparent;
        color: var(--primary);
        border: 3px solid var(--primary);
    }

    .action-btn.delete:hover {
        background: var(--primary);
        color: white;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 100px 40px;
        background: var(--card-bg);
        border: 4px dashed var(--dark);
    }

    .empty-icon {
        width: 120px;
        height: 120px;
        margin: 0 auto 32px;
        background: var(--accent);
        border: 4px solid var(--dark);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .empty-icon svg {
        width: 60px;
        height: 60px;
        color: var(--dark);
    }

    .empty-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 48px;
        color: var(--dark);
        margin-bottom: 16px;
        text-transform: uppercase;
    }

    .empty-text {
        font-size: 16px;
        color: var(--text-muted);
        margin-bottom: 32px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }

    /* Pagination */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        margin-top: 56px;
    }

    .page-btn {
        width: 48px;
        height: 48px;
        border: 3px solid var(--dark);
        background: white;
        color: var(--dark);
        font-family: 'Bebas Neue', sans-serif;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .page-btn:hover:not(:disabled) {
        background: var(--dark);
        color: white;
    }

    .page-btn.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .page-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    /* Responsive */
    @@media (max-width: 1200px) {
        .sections-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .getintouch-list-container {
            padding: 40px 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: stretch;
        }

        .page-title {
            font-size: 48px;
        }

        .header-actions {
            width: 100%;
        }

        .btn-primary {
            flex: 1;
        }

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .stat-item {
            border-right: none;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            padding: 0 0 20px 0;
        }

        .stat-item:nth-last-child(-n+2) {
            border-bottom: none;
            padding-bottom: 0;
        }

        .control-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            min-width: 100%;
        }
    }

    @@media (max-width: 480px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .stat-item {
            padding: 0 0 20px 0;
        }

        .stat-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }
    }
</style>

<div class="getintouch-list-container">
    <div class="page-header">
        <div class="header-left">
            <div class="header-tag">BÖLÜM YÖNETİCİSİ</div>
            <h1 class="page-title">İletişim<br>Bölümleri</h1>
            <p class="page-subtitle">Tüm iletişim bölümlerini yönetin</p>
        </div>
        <div class="header-actions">
            <a href="/GetInTouch/CreateSection" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Yeni Ekle
            </a>
            <button class="btn btn-icon" title="Yenile" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="24" height="24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <div class="stats-terminal">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-label">Toplam</div>
                <div class="stat-value">@Model.Count</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Aktif</div>
                <div class="stat-value">@Model.Count(x => x.Status)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Pasif</div>
                <div class="stat-value">@Model.Count(x => !x.Status)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Özellikler</div>
                <div class="stat-value">@(Model.Count * 2)</div>
            </div>
        </div>
    </div>

    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="BÖLÜMLERİ ARA..." />
        </div>
        <div class="filter-toggle">
            <button class="filter-btn active" data-filter="all">Tümü</button>
            <button class="filter-btn" data-filter="active">Aktif</button>
            <button class="filter-btn" data-filter="inactive">Pasif</button>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="sections-grid" id="sectionsGrid">
            @for (int i = 0; i < Model.Count; i++)
            {
                var section = Model[i];
                <div class="section-card" 
                     data-id="@(i + 1)" 
                     data-status="@(section.Status ? "active" : "inactive")"
                     data-title="@Model[i].MainTitle.ToLower()">
                    <div class="card-header">
                        <div class="card-badge">@Model[i].BadgeTitle</div>
                        <h3 class="card-title">@Model[i].MainTitle</h3>
                        <p class="card-description">@Model[i].Description</p>
                    </div>
                    <div class="card-body">
                        <div class="features-list">
                            <div class="feature-item">
                                <h4 class="feature-item-title">@Model[i].Feature1Title</h4>
                                <p class="feature-item-desc">@Model[i].Feature1Description</p>
                            </div>
                            <div class="feature-item">
                                <h4 class="feature-item-title">@Model[i].Feature2Title</h4>
                                <p class="feature-item-desc">@Model[i].Feature2Description</p>
                            </div>
                        </div>

                        <div class="card-meta">
                            <div class="meta-info">
                                <div class="meta-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                    </svg>
                                    ID: @Model[i].GetInTouchId
                                </div>
                            </div>
                            <div class="status-badge @(section.Status ? "active" : "inactive")">
                                @(section.Status ? "[AKTİF]" : "[PASİF]")
                            </div>
                        </div>

                        <div class="card-actions">
                            <a href="/GetInTouch/UpdateSection/@Model[i].GetInTouchId" class="action-btn edit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Düzenle
                            </a>
                            <a href="/GetInTouch/DeleteSection/@Model[i].GetInTouchId" 
                               class="action-btn delete" 
                               onclick="return confirm('Bu bölümü silmek istediğinizden emin misiniz?')">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Sil
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="pagination">
            <button class="page-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <h3 class="empty-title">Bölüm Bulunamadı</h3>
            <p class="empty-text">İletişim bölümü oluşturarak başlayın</p>
            <a href="/GetInTouch/CreateSection" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                İlk Bölümü Oluşturun
            </a>
        </div>
    }
</div>

<script>
    // Arama işlevi
    const searchInput = document.getElementById('searchInput');
    const sectionsGrid = document.getElementById('sectionsGrid');

    if (searchInput && sectionsGrid) {
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();
            const cards = sectionsGrid.querySelectorAll('.section-card');

            cards.forEach(card => {
                const title = card.getAttribute('data-title');
                card.style.display = title.includes(searchTerm) ? '' : 'none';
            });
        });
    }

    // Filtreleme işlevi
    const filterButtons = document.querySelectorAll('.filter-btn');
    
    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            filterButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            const filter = btn.getAttribute('data-filter');
            const cards = document.querySelectorAll('.section-card');

            cards.forEach(card => {
                const status = card.getAttribute('data-status');
                
                if (filter === 'all') {
                    card.style.display = '';
                } else {
                    card.style.display = status === filter ? '' : 'none';
                }
            });
        });
    });

    // Kartlar için kademeli animasyon
    const sectionCards = document.querySelectorAll('.section-card');
    sectionCards.forEach((card, index) => {
        card.style.animationDelay = `${0.4 + (index * 0.08)}s`;
    });
</script>