    // Populate cities
    function populateCities() {
        const cities = Object.keys(turkeyData).sort();
        const originCitySelect = document.getElementById('originCitySelect');
        const destinationCitySelect = document.getElementById('destinationCitySelect');

        cities.forEach(city => {
            const option1 = new Option(city, city);
            const option2 = new Option(city, city);
            originCitySelect.add(option1);
            destinationCitySelect.add(option2);
        });
    }

    // Populate districts based on city
    function populateDistricts(citySelectId, districtSelectId) {
        const citySelect = document.getElementById(citySelectId);
        const districtSelect = document.getElementById(districtSelectId);

        citySelect.addEventListener('change', function() {
            const selectedCity = this.value;
            districtSelect.innerHTML = '<option value="">İlçe Seçiniz</option>';

            if (selectedCity && turkeyData[selectedCity]) {
                districtSelect.disabled = false;
                turkeyData[selectedCity].forEach(district => {
                    const option = new Option(district, district);
                    districtSelect.add(option);
                });
                updatePreview();
            } else {
                districtSelect.disabled = true;
            }
        });

        districtSelect.addEventListener('change', updatePreview);
    }

    // Auto-generate tracking number
    function generateTrackingNumber() {
        const prefix = 'TRK-';
        const random = Math.random().toString(36).substring(2, 10).toUpperCase();
        return prefix + random;
    }

    // Set default date
    function setDefaultDate() {
        const now = new Date();
        const offset = now.getTimezoneOffset();
        const adjustedDate = new Date(now.getTime() - offset * 60 * 1000);
        const dateString = adjustedDate.toISOString().slice(0, 16);
        document.getElementById('dateInput').value = dateString;
        updatePreview();
    }

    // Update preview
    function updatePreview() {
        const trackingInput = document.getElementById('trackingInput');
        const senderInput = document.getElementById('senderInput');
        const receiverInput = document.getElementById('receiverInput');
        const originCitySelect = document.getElementById('originCitySelect');
        const originDistrictSelect = document.getElementById('originDistrictSelect');
        const destinationCitySelect = document.getElementById('destinationCitySelect');
        const destinationDistrictSelect = document.getElementById('destinationDistrictSelect');
        const addressInput = document.getElementById('addressInput');
        const dateInput = document.getElementById('dateInput');
        const statusInput = document.getElementById('statusInput');

        document.getElementById('previewTracking').textContent = trackingInput?.value || 'TRK-XXXXXXXX';
        document.getElementById('previewSender').textContent = senderInput?.value || '-';
        document.getElementById('previewReceiver').textContent = receiverInput?.value || '-';

        const originFull = originCitySelect?.value && originDistrictSelect?.value
            ? `${originCitySelect.value} / ${originDistrictSelect.value}`
            : 'Çıkış: Şehir / İlçe';
        document.getElementById('previewOriginFull').textContent = originFull;

        const destFull = destinationCitySelect?.value && destinationDistrictSelect?.value
            ? `${destinationCitySelect.value} / ${destinationDistrictSelect.value}`
            : 'Varış: Şehir / İlçe';
        document.getElementById('previewDestinationFull').textContent = destFull;

        const address = addressInput?.value || '-';
        document.getElementById('previewAddress').textContent = address.length > 50 ? address.substring(0, 50) + '...' : address;

        if (dateInput?.value) {
            const date = new Date(dateInput.value);
            const formatted = date.toLocaleDateString('tr-TR', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
            document.getElementById('previewDate').textContent = formatted;
        }

        document.getElementById('previewStatus').textContent = statusInput?.value || 'Bekliyor';
    }

    // Initialize
    window.addEventListener('load', function() {
        populateCities();
        populateDistricts('originCitySelect', 'originDistrictSelect');
        populateDistricts('destinationCitySelect', 'destinationDistrictSelect');

        const trackingInput = document.getElementById('trackingInput');
        if (!trackingInput.value) {
            trackingInput.value = generateTrackingNumber();
        }
        setDefaultDate();

        // Add event listeners for preview
        ['trackingInput', 'senderInput', 'receiverInput', 'addressInput', 'dateInput', 'statusInput'].forEach(id => {
            const element = document.getElementById(id);
            if (element) {
                element.addEventListener('input', updatePreview);
                element.addEventListener('change', updatePreview);
            }
        });

        updatePreview();
    });

    // Form validation
    document.getElementById('shipmentForm')?.addEventListener('submit', (e) => {
        const originCity = document.getElementById('originCitySelect').value;
        const originDistrict = document.getElementById('originDistrictSelect').value;
        const destCity = document.getElementById('destinationCitySelect').value;
        const destDistrict = document.getElementById('destinationDistrictSelect').value;

        if (!originCity || !originDistrict || !destCity || !destDistrict) {
            e.preventDefault();
            alert('Lütfen çıkış ve varış şehir/ilçe bilgilerini eksiksiz doldurun!');
            return false;
        }

        if (originCity === destCity && originDistrict === destDistrict) {
            e.preventDefault();
            alert('Çıkış ve varış lokasyonu aynı olamaz!');
            return false;
        }
    });
</script>
