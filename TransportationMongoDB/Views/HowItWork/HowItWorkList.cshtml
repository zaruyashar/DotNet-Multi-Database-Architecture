@model List<ResultHowItWorkDto>

@{
    ViewData["Title"] = "HowItWorkList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800;900&family=Quicksand:wght@400;500;600;700&display=swap');

    :root {
        --primary: #6B5CE0;
        --primary-light: #8A7FEA;
        --accent: #FFB84D;
        --accent-light: #FFD085;
        --success: #4ECDC4;
        --pink: #FF6B9D;
        --bg: #F8F9FD;
        --card-bg: #FFFFFF;
        --text: #2D3748;
        --text-muted: #718096;
        --border: #E2E8F0;
        --shadow-sm: 0 2px 12px rgba(107, 92, 224, 0.08);
        --shadow-md: 0 8px 24px rgba(107, 92, 224, 0.12);
        --shadow-lg: 0 16px 40px rgba(107, 92, 224, 0.15);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Nunito', sans-serif;
        background: var(--bg);
        color: var(--text);
    }

        /* Soft Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(107, 92, 224, 0.05) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(255, 107, 157, 0.05) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(78, 205, 196, 0.03) 0%, transparent 50%);
            z-index: 0;
            pointer-events: none;
        }

    .howitwork-list-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 56px 32px;
        position: relative;
        z-index: 1;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(25px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 48px;
        gap: 32px;
        flex-wrap: wrap;
    }

    .header-left {
        flex: 1;
        min-width: 300px;
    }

    .header-decoration {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
    }

    .decoration-circle {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        animation: float 3s ease-in-out infinite;
    }

        .decoration-circle:nth-child(1) {
            background: var(--primary);
            animation-delay: 0s;
        }

        .decoration-circle:nth-child(2) {
            background: var(--accent);
            animation-delay: 0.2s;
        }

        .decoration-circle:nth-child(3) {
            background: var(--pink);
            animation-delay: 0.4s;
        }

        .decoration-circle:nth-child(4) {
            background: var(--success);
            animation-delay: 0.6s;
        }

    @@keyframes float {
        0%, 100%

    {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-8px);
    }

    }

    .page-title {
        font-size: 42px;
        font-weight: 900;
        background: linear-gradient(135deg, var(--primary), var(--pink));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 12px;
        line-height: 1.2;
    }

    .page-subtitle {
        font-size: 16px;
        color: var(--text-muted);
        font-weight: 600;
    }

    .header-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn {
        padding: 16px 28px;
        font-size: 15px;
        font-weight: 800;
        border-radius: 16px;
        border: none;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Nunito', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        position: relative;
        overflow: hidden;
    }

        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn span,
        .btn svg {
            position: relative;
            z-index: 1;
        }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: white;
        box-shadow: var(--shadow-md);
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }

    .btn-icon {
        background: white;
        color: var(--primary);
        width: 48px;
        height: 48px;
        padding: 0;
        justify-content: center;
        border: 2px solid var(--border);
        box-shadow: var(--shadow-sm);
    }

        .btn-icon:hover {
            border-color: var(--primary);
            background: var(--primary);
            color: white;
        }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
        margin-bottom: 48px;
        animation: slideUp 0.8s ease-out 0.1s both;
    }

    @@keyframes slideUp {
        from

    {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .stat-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(107, 92, 224, 0.1);
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
        }

        .stat-card:nth-child(1)::before {
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
        }

        .stat-card:nth-child(2)::before {
            background: linear-gradient(90deg, var(--success), #3DB8B0);
        }

        .stat-card:nth-child(3)::before {
            background: linear-gradient(90deg, var(--pink), #FF8AB5);
        }

        .stat-card:nth-child(4)::before {
            background: linear-gradient(90deg, var(--accent), var(--accent-light));
        }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
        }

    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .stat-card:nth-child(1) .stat-icon {
        background: linear-gradient(135deg, rgba(107, 92, 224, 0.1), rgba(107, 92, 224, 0.05));
        color: var(--primary);
    }

    .stat-card:nth-child(2) .stat-icon {
        background: linear-gradient(135deg, rgba(78, 205, 196, 0.1), rgba(78, 205, 196, 0.05));
        color: var(--success);
    }

    .stat-card:nth-child(3) .stat-icon {
        background: linear-gradient(135deg, rgba(255, 107, 157, 0.1), rgba(255, 107, 157, 0.05));
        color: var(--pink);
    }

    .stat-card:nth-child(4) .stat-icon {
        background: linear-gradient(135deg, rgba(255, 184, 77, 0.1), rgba(255, 184, 77, 0.05));
        color: var(--accent);
    }

    .stat-icon svg {
        width: 28px;
        height: 28px;
    }

    .stat-label {
        font-size: 13px;
        color: var(--text-muted);
        font-weight: 700;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-family: 'Quicksand', sans-serif;
    }

    .stat-value {
        font-size: 36px;
        font-weight: 900;
        color: var(--text);
        line-height: 1;
    }

    /* Control Bar */
    .control-bar {
        background: var(--card-bg);
        padding: 20px 28px;
        border-radius: 20px;
        border: 1px solid rgba(107, 92, 224, 0.1);
        box-shadow: var(--shadow-sm);
        margin-bottom: 40px;
        display: flex;
        gap: 20px;
        align-items: center;
        flex-wrap: wrap;
        animation: slideUp 0.8s ease-out 0.2s both;
    }

    .search-box {
        flex: 1;
        min-width: 300px;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 14px 20px 14px 48px;
        border: 2px solid var(--border);
        border-radius: 14px;
        font-size: 15px;
        font-family: 'Nunito', sans-serif;
        font-weight: 600;
        background: var(--bg);
        color: var(--text);
        transition: all 0.3s ease;
    }

        .search-input:focus {
            outline: none;
            border-color: var(--primary);
            background: white;
            box-shadow: 0 0 0 4px rgba(107, 92, 224, 0.1);
        }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        color: var(--text-muted);
        pointer-events: none;
    }

    .filter-group {
        display: flex;
        gap: 8px;
        background: var(--bg);
        padding: 6px;
        border-radius: 12px;
    }

    .filter-btn {
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 700;
        border-radius: 10px;
        border: none;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Nunito', sans-serif;
    }

        .filter-btn:hover {
            color: var(--primary);
        }

        .filter-btn.active {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white;
            box-shadow: 0 4px 12px rgba(107, 92, 224, 0.25);
        }

    /* Steps Grid */
    .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 32px;
        animation: slideUp 0.8s ease-out 0.3s both;
    }

    .step-card {
        background: var(--card-bg);
        border-radius: 28px;
        border: 1px solid rgba(107, 92, 224, 0.1);
        box-shadow: var(--shadow-md);
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        animation: fadeInScale 0.6s ease-out both;
    }

    @@keyframes fadeInScale {
        from

    {
        opacity: 0;
        transform: scale(0.95);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }

    }

    .step-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, var(--accent), var(--accent-light));
    }

    .step-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: var(--shadow-lg);
        border-color: rgba(107, 92, 224, 0.3);
    }

    .card-header {
        padding: 36px;
        background: linear-gradient(135deg, rgba(107, 92, 224, 0.05), rgba(255, 107, 157, 0.05));
        text-align: center;
    }

    .icon-wrapper {
        width: 100px;
        height: 100px;
        background: var(--accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        box-shadow: 0 8px 24px rgba(255, 184, 77, 0.3);
        border: 6px solid rgba(255, 255, 255, 0.5);
        transition: transform 0.5s ease;
    }

    .step-card:hover .icon-wrapper {
        transform: scale(1.1) rotate(5deg);
    }

    .icon-wrapper img {
        width: 50px;
        height: 50px;
        object-fit: contain;
    }

    .icon-placeholder {
        width: 50px;
        height: 50px;
        color: white;
    }

    .step-number {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 900;
        color: white;
        box-shadow: 0 4px 12px rgba(107, 92, 224, 0.3);
        font-family: 'Quicksand', sans-serif;
    }

    .card-content {
        padding: 32px;
    }

    .step-title {
        font-size: 22px;
        font-weight: 900;
        color: var(--text);
        margin-bottom: 12px;
        line-height: 1.3;
        text-align: center;
    }

    .step-description {
        font-size: 15px;
        color: var(--text-muted);
        line-height: 1.7;
        margin-bottom: 24px;
        text-align: center;
        font-weight: 600;
    }

    .card-meta {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
        padding-top: 20px;
        margin-top: 20px;
        border-top: 2px solid var(--border);
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 700;
        font-family: 'Quicksand', sans-serif;
    }

        .meta-item svg {
            width: 14px;
            height: 14px;
            color: var(--primary);
        }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        font-family: 'Quicksand', sans-serif;
    }

        .status-badge.active {
            background: linear-gradient(135deg, rgba(78, 205, 196, 0.15), rgba(78, 205, 196, 0.1));
            color: var(--success);
        }

        .status-badge.inactive {
            background: linear-gradient(135deg, rgba(113, 128, 150, 0.15), rgba(113, 128, 150, 0.1));
            color: var(--text-muted);
        }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100%

    {
        opacity: 1;
        transform: scale(1);
    }

    50% {
        opacity: 0.5;
        transform: scale(1.2);
    }

    }

    .card-actions {
        display: flex;
        gap: 12px;
        margin-top: 20px;
    }

    .action-btn {
        flex: 1;
        padding: 12px 20px;
        font-size: 14px;
        font-weight: 800;
        border-radius: 12px;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Nunito', sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
    }

        .action-btn svg {
            width: 16px;
            height: 16px;
        }

        .action-btn.edit {
            background: linear-gradient(135deg, rgba(107, 92, 224, 0.12), rgba(107, 92, 224, 0.08));
            color: var(--primary);
        }

            .action-btn.edit:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-light));
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(107, 92, 224, 0.25);
            }

        .action-btn.delete {
            background: linear-gradient(135deg, rgba(255, 107, 157, 0.12), rgba(255, 107, 157, 0.08));
            color: var(--pink);
        }

            .action-btn.delete:hover {
                background: linear-gradient(135deg, var(--pink), #FF8AB5);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(255, 107, 157, 0.25);
            }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 100px 40px;
        background: var(--card-bg);
        border-radius: 32px;
        border: 2px dashed rgba(107, 92, 224, 0.2);
    }

    .empty-icon {
        width: 120px;
        height: 120px;
        margin: 0 auto 28px;
        background: linear-gradient(135deg, rgba(107, 92, 224, 0.1), rgba(255, 107, 157, 0.1));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .empty-icon svg {
            width: 60px;
            height: 60px;
            color: var(--primary);
        }

    .empty-title {
        font-size: 32px;
        font-weight: 900;
        background: linear-gradient(135deg, var(--primary), var(--pink));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 12px;
    }

    .empty-text {
        font-size: 16px;
        color: var(--text-muted);
        margin-bottom: 32px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
        font-weight: 600;
    }

    /* Pagination */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 56px;
    }

    .page-btn {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        border: 2px solid var(--border);
        background: white;
        color: var(--text);
        font-weight: 800;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .page-btn:hover:not(:disabled) {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(107, 92, 224, 0.05);
        }

        .page-btn.active {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white;
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(107, 92, 224, 0.25);
        }

        .page-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

    /* Responsive */
    @@media (max-width: 1024px) {
        .steps-grid

    {
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    }

    @@media (max-width: 768px) {
        .howitwork-list-container

    {
        padding: 40px 20px;
    }

    .page-header {
        flex-direction: column;
        align-items: stretch;
    }

    .page-title {
        font-size: 32px;
    }

    .header-actions {
        width: 100%;
    }

    .btn-primary {
        flex: 1;
    }

    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .control-bar {
        flex-direction: column;
        align-items: stretch;
    }

    .search-box {
        min-width: 100%;
    }

    .steps-grid {
        grid-template-columns: 1fr;
    }

    }

    @@media (max-width: 480px) {
        .stats-grid

    {
        grid-template-columns: 1fr;
    }

    }
</style>

<div class="howitwork-list-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-left">
            <div class="header-decoration">
                <div class="decoration-circle"></div>
                <div class="decoration-circle"></div>
                <div class="decoration-circle"></div>
                <div class="decoration-circle"></div>
            </div>
            <h1 class="page-title">Nasıl Çalışır Adımları</h1>
            <p class="page-subtitle">Tüm süreç adımlarını görüntüleyin ve yönetin</p>
        </div>
        <div class="header-actions">
            <a href="/HowItWork/CreateHowItWork/" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>Yeni Adım</span>
            </a>
            <button class="btn btn-icon" title="Yenile" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="22" height="22">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <div class="stat-label">Toplam Adım</div>
            <div class="stat-value">@Model.Count</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div class="stat-label">Aktif</div>
            <div class="stat-value">@Model.Count(x => x.Status)</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div class="stat-label">Pasif</div>
            <div class="stat-value">@Model.Count(x => !x.Status)</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
            </div>
            <div class="stat-label">Görüntülenme</div>
            <div class="stat-value">@(Model.Count * 1847)</div>
        </div>
    </div>

    <!-- Control Bar -->
    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Adım ara..." />
        </div>
        <div class="filter-group">
            <button class="filter-btn active" data-filter="all">Tümü</button>
            <button class="filter-btn" data-filter="active">Aktif</button>
            <button class="filter-btn" data-filter="inactive">Pasif</button>
        </div>
    </div>

    <!-- Steps Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="steps-grid" id="stepsGrid">
            @for (int i = 0; i < Model.Count; i++)
            {
                var step = Model[i];
                <div class="step-card"
                     data-status="@(step.Status ? "active" : "inactive")"
                     data-title="@step.Title.ToLower()">
                    <div class="card-header">
                        <div class="step-number">@(i + 1)</div>
                        <div class="icon-wrapper">
                            <img src="@step.IconUrl" alt="@step.Title" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                            <svg class="icon-placeholder" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:none;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                        </div>
                    </div>
                    <div class="card-content">
                        <h3 class="step-title">@step.Title</h3>
                        <p class="step-description">@step.Description</p>

                        <div class="card-meta">
                            <div class="meta-item">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                </svg>
                                ID: @step.HowItWorkId
                            </div>
                            <div class="status-badge @(step.Status ? "active" : "inactive")">
                                <span class="status-dot"></span>
                                @(step.Status ? "Aktif" : "Pasif")
                            </div>
                        </div>

                        <div class="card-actions">
                            <a href="/HowItWork/UpdateHowItWork/@step.HowItWorkId" class="action-btn edit">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Düzenle
                            </a>
                            <a href="/HowItWork/DeleteHowItWork/@step.HowItWorkId"
                               class="action-btn delete"
                               onclick="return confirm('Bu adımı silmek istediğinizden emin misiniz?')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Sil
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pagination">
            <button class="page-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <h3 class="empty-title">Henüz Adım Yok</h3>
            <p class="empty-text">Müşterilerinize sürecinizi göstermek için ilk adımı oluşturun</p>
            <a href="/HowItWork/CreateHowItWork/" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>İlk Adımı Oluştur</span>
            </a>
        </div>
    }
</div>

<script>
    // Search functionality
    const searchInput = document.getElementById('searchInput');
    const stepsGrid = document.getElementById('stepsGrid');

    if (searchInput && stepsGrid) {
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();
            const cards = stepsGrid.querySelectorAll('.step-card');

            cards.forEach(card => {
                const title = card.getAttribute('data-title');
                card.style.display = title.includes(searchTerm) ? '' : 'none';
            });
        });
    }

    // Filter functionality
    const filterButtons = document.querySelectorAll('.filter-btn');

    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            filterButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const filter = btn.getAttribute('data-filter');
            const cards = document.querySelectorAll('.step-card');

            cards.forEach(card => {
                const status = card.getAttribute('data-status');

                if (filter === 'all') {
                    card.style.display = '';
                } else {
                    card.style.display = status === filter ? '' : 'none';
                }
            });
        });
    });

    // Stagger animation for cards
    const stepCards = document.querySelectorAll('.step-card');
    stepCards.forEach((card, index) => {
        card.style.animationDelay = `${0.4 + (index * 0.05)}s`;
    });
</script>
