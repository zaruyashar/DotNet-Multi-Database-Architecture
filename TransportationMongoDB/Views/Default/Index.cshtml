@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">

@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<body>
    
    @await Component.InvokeAsync("_DefaultBoxBarComponentPartial")

    @await Component.InvokeAsync("_DefaultHeaderComponentPartial")

    @await Component.InvokeAsync("_DefaultMobileMenuComponentPartial")

    <main class="main">

        @await Component.InvokeAsync("_DefaultSliderComponentPartial")

        @await Component.InvokeAsync("_DefaultBrandComponentPartial")

        @await Component.InvokeAsync("_DefaultOfferComponentPartial")

        @await Component.InvokeAsync("_DefaultAboutComponentPartial")

        @await Component.InvokeAsync("_DefaultGetInTouchComponentPartial")

        @await Component.InvokeAsync("_DefaultHowItWorksComponentPartial")

        @await Component.InvokeAsync("_DefaultTestimonialComponentPartial")

        @await Component.InvokeAsync("_DefaultWhatWeHaveDoneComponentPartial")
        
        <section class="section bg-leading-company pt-95">
            <div class="box-bg-leading"></div>
            <div class="container">

                @await Component.InvokeAsync("_DefaultStatisticsComponentPartial")

                @await Component.InvokeAsync("_DefaultCalculateShippingViewComponentPartial")
            </div>
        </section>

        @await Component.InvokeAsync("_DefaultPlanComponentPartial")
        
        @await Component.InvokeAsync("_DefaultFAQComponentPartial")

        @await Component.InvokeAsync("_DefaultGetQuoteComponentPartial")

        @await Component.InvokeAsync("_DefaultContactComponentPartial")
</main>
    @await Component.InvokeAsync("_DefaultFooterComponentPartial")

    @await Component.InvokeAsync("_DefaultScriptComponentPartial")
</body>
</html>