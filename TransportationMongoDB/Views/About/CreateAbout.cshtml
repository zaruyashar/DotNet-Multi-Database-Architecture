@model CreateAboutDto
@{
    ViewData["Title"] = "CreateAbout";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap');

    :root {
        --dark: #0F172A;
        --dark-light: #1E293B;
        --accent: #10B981;
        --accent-dark: #059669;
        --secondary: #3B82F6;
        --warning: #F59E0B;
        --danger: #EF4444;
        --bg: #F8FAFC;
        --card-bg: #FFFFFF;
        --text: #0F172A;
        --text-muted: #64748B;
        --border: #E2E8F0;
        --shadow-sm: 0 1px 3px rgba(15, 23, 42, 0.08);
        --shadow-md: 0 4px 16px rgba(15, 23, 42, 0.12);
        --shadow-lg: 0 8px 32px rgba(15, 23, 42, 0.16);
        --shadow-xl: 0 16px 48px rgba(15, 23, 42, 0.20);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Archivo', sans-serif;
        background: var(--bg);
        color: var(--text);
        position: relative;
    }

    /* Diagonal Background Pattern */
    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background:
            linear-gradient(135deg, transparent 48%, rgba(16, 185, 129, 0.03) 49%, rgba(16, 185, 129, 0.03) 51%, transparent 52%);
        background-size: 60px 60px;
        z-index: 0;
        pointer-events: none;
    }

    .about-create-container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 56px 32px;
        position: relative;
        z-index: 1;
        animation: fadeIn 0.9s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Header Section */
    .page-header {
        margin-bottom: 56px;
        position: relative;
    }

    .header-top {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .header-line {
        width: 80px;
        height: 4px;
        background: linear-gradient(90deg, var(--accent), transparent);
        border-radius: 2px;
    }

    .header-label {
        font-size: 13px;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 2px;
        font-family: 'IBM Plex Mono', monospace;
    }

    .page-title {
        font-size: 48px;
        font-weight: 900;
        color: var(--dark);
        margin-bottom: 16px;
        letter-spacing: -1.5px;
        line-height: 1.1;
    }

    .title-highlight {
        position: relative;
        display: inline-block;
    }

    .title-highlight::after {
        content: '';
        position: absolute;
        bottom: 8px;
        left: 0;
        right: 0;
        height: 16px;
        background: linear-gradient(90deg, rgba(16, 185, 129, 0.3), transparent);
        z-index: -1;
    }

    .page-subtitle {
        font-size: 18px;
        color: var(--text-muted);
        max-width: 700px;
        line-height: 1.7;
    }

    /* Split Layout */
    .split-layout {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 48px;
        animation: slideUp 0.9s ease-out 0.2s both;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(50px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Main Form Column */
    .form-column {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .form-section {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 40px;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    }

    .form-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 6px;
        height: 100%;
        background: linear-gradient(180deg, var(--accent), var(--accent-dark));
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
        padding-left: 20px;
    }

    .section-number {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, var(--accent), var(--accent-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 900;
        color: white;
        font-family: 'IBM Plex Mono', monospace;
        box-shadow: 0 4px 16px rgba(16, 185, 129, 0.3);
    }

    .section-title {
        font-size: 22px;
        font-weight: 800;
        color: var(--dark);
        letter-spacing: -0.5px;
    }

    /* Form Groups */
    .form-group {
        margin-bottom: 28px;
        animation: fadeInUp 0.7s ease-out both;
    }

    .form-group:nth-child(1) { animation-delay: 0.1s; }
    .form-group:nth-child(2) { animation-delay: 0.15s; }
    .form-group:nth-child(3) { animation-delay: 0.2s; }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(25px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .form-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .label-text {
        font-size: 15px;
        font-weight: 700;
        color: var(--dark);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-family: 'IBM Plex Mono', monospace;
    }

    .label-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 12px;
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.12), rgba(239, 68, 68, 0.08));
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        color: var(--danger);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-input,
    .form-textarea {
        width: 100%;
        padding: 20px 24px;
        font-size: 16px;
        font-family: 'Archivo', sans-serif;
        border: 3px solid var(--border);
        border-radius: 16px;
        background: var(--bg);
        color: var(--text);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        outline: none;
        font-weight: 500;
    }

    .form-input:focus,
    .form-textarea:focus {
        border-color: var(--accent);
        background: white;
        box-shadow: 0 0 0 6px rgba(16, 185, 129, 0.12);
        transform: translateY(-3px);
    }

    .form-textarea {
        resize: vertical;
        min-height: 180px;
        line-height: 1.8;
    }

    .input-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
    }

    .char-count {
        font-size: 12px;
        color: var(--text-muted);
        font-family: 'IBM Plex Mono', monospace;
        font-weight: 600;
    }

    .input-hint {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--text-muted);
    }

    .input-hint svg {
        width: 16px;
        height: 16px;
        color: var(--accent);
    }

    /* Image Upload Section */
    .image-upload-area {
        border: 3px dashed var(--border);
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.03), transparent);
        transition: all 0.4s ease;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .image-upload-area:hover {
        border-color: var(--accent);
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.08), transparent);
    }

    .upload-icon-wrapper {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--accent), var(--accent-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3);
        animation: bounce 2s ease-in-out infinite;
    }

    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .upload-icon-wrapper svg {
        width: 40px;
        height: 40px;
        color: white;
    }

    .upload-text {
        font-size: 16px;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 8px;
    }

    .upload-hint {
        font-size: 13px;
        color: var(--text-muted);
    }

    /* Preview Column */
    .preview-column {
        position: sticky;
        top: 24px;
        height: fit-content;
    }

    .preview-wrapper {
        background: linear-gradient(135deg, var(--dark), var(--dark-light));
        border-radius: 28px;
        padding: 48px;
        box-shadow: var(--shadow-xl);
        position: relative;
        overflow: hidden;
        animation: slideUp 0.9s ease-out 0.3s both;
    }

    .preview-wrapper::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -30%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(16, 185, 129, 0.15) 0%, transparent 70%);
        animation: float 12s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(30px, -30px) rotate(120deg); }
        66% { transform: translate(-20px, 20px) rotate(240deg); }
    }

    .preview-content {
        position: relative;
        z-index: 1;
    }

    .preview-label {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 28px;
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.7);
        text-transform: uppercase;
        letter-spacing: 2px;
        font-family: 'IBM Plex Mono', monospace;
    }

    .preview-label-dot {
        width: 8px;
        height: 8px;
        background: var(--accent);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.2); }
    }

    .preview-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(20px);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 40px;
        min-height: 500px;
        display: flex;
        flex-direction: column;
    }

    .preview-image-container {
        width: 100%;
        height: 280px;
        background: rgba(16, 185, 129, 0.15);
        border-radius: 20px;
        margin-bottom: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .preview-image-container::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(45deg, transparent 30%, rgba(255, 255, 255, 0.05) 50%, transparent 70%);
        animation: shimmer 3s infinite;
    }

    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    #previewImage {
        max-width: 100%;
        max-height: 100%;
        object-fit: cover;
        border-radius: 16px;
        display: none;
        position: relative;
        z-index: 1;
    }

    #previewImage.show {
        display: block;
    }

    .preview-placeholder {
        text-align: center;
    }

    .preview-placeholder-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 16px;
        opacity: 0.4;
    }

    .preview-placeholder-icon svg {
        width: 100%;
        height: 100%;
        color: white;
    }

    .preview-placeholder-text {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.5);
    }

    .preview-title {
        font-size: 28px;
        font-weight: 900;
        color: white;
        margin-bottom: 16px;
        line-height: 1.3;
        letter-spacing: -0.5px;
    }

    .preview-description {
        font-size: 15px;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.8;
    }

    /* Info Card */
    .info-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border);
        margin-top: 32px;
        animation: slideUp 0.9s ease-out 0.4s both;
    }

    .info-card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }

    .info-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, var(--secondary), #2563EB);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .info-icon svg {
        width: 20px;
        height: 20px;
        color: white;
    }

    .info-card-title {
        font-size: 16px;
        font-weight: 800;
        color: var(--dark);
    }

    .info-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .info-list li {
        display: flex;
        align-items: start;
        gap: 12px;
        font-size: 14px;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .info-list-icon {
        width: 20px;
        height: 20px;
        background: var(--accent);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .info-list-icon svg {
        width: 12px;
        height: 12px;
        color: white;
    }

    /* Action Buttons */
    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 48px;
        padding-top: 40px;
        border-top: 3px solid var(--border);
    }

    .btn {
        flex: 1;
        padding: 20px 32px;
        font-size: 16px;
        font-weight: 800;
        border-radius: 16px;
        border: none;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Archivo', sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        position: relative;
        overflow: hidden;
    }

    .btn::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn:hover::before {
        width: 400px;
        height: 400px;
    }

    .btn span,
    .btn svg {
        position: relative;
        z-index: 1;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--accent), var(--accent-dark));
        color: white;
        box-shadow: var(--shadow-lg);
    }

    .btn-primary:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-xl);
    }

    .btn-secondary {
        background: white;
        color: var(--dark);
        border: 3px solid var(--border);
    }

    .btn-secondary:hover {
        border-color: var(--dark);
        background: var(--bg);
    }

    /* Responsive */
    @@media (max-width: 1200px) {
        .split-layout {
            grid-template-columns: 1fr;
        }

        .preview-column {
            position: relative;
            top: 0;
        }
    }

    @@media (max-width: 768px) {
        .about-create-container {
            padding: 32px 20px;
        }

        .page-title {
            font-size: 36px;
        }

        .form-section {
            padding: 32px 24px;
        }

        .preview-wrapper {
            padding: 32px 24px;
        }

        .form-actions {
            flex-direction: column-reverse;
        }
    }
</style>

<div class="about-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-top">
            <div class="header-line"></div>
            <span class="header-label">HAKKIMIZDA İÇERİĞİ</span>
        </div>
        <h1 class="page-title">
            <span class="title-highlight">Kurumsal</span> Hikayenizi Anlatın
        </h1>
        <p class="page-subtitle">
            Firmanızın değerlerini, vizyonunu ve hikayesini müşterilerinizle paylaşmak için hakkımızda içeriği oluşturun.
        </p>
    </div>

    <!-- Split Layout -->
    <form method="post" id="aboutForm">
        <div class="split-layout">
            <!-- Form Column -->
            <div class="form-column">
                <!-- Section 1: Content -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">01</div>
                        <h2 class="section-title">İçerik Bilgileri</h2>
                    </div>

                    <div class="form-group">
                        <div class="form-label">
                            <span class="label-text">Başlık</span>
                            <span class="label-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="8" />
                                </svg>
                                Zorunlu
                            </span>
                        </div>
                        <input type="text"
                               class="form-input"
                               asp-for="Title"
                               id="titleInput"
                               placeholder="Örn: Bizim Hikayemiz, Kimiz Biz, Misyonumuz..."
                               maxlength="150"
                               required />
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Kısa ve etkileyici bir başlık kullanın
                            </div>
                            <span class="char-count">
                                <span id="titleCounter">0</span> / 150
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="form-label">
                            <span class="label-text">Açıklama</span>
                            <span class="label-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="8" />
                                </svg>
                                Zorunlu
                            </span>
                        </div>
                        <textarea class="form-textarea"
                                  asp-for="Description"
                                  id="descriptionInput"
                                  placeholder="Firmanızın hikayesini, değerlerini ve vizyonunu buraya yazın..."
                                  maxlength="1000"
                                  required></textarea>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Samimi ve içten bir dil kullanın
                            </div>
                            <span class="char-count">
                                <span id="descCounter">0</span> / 1000
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Image -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">02</div>
                        <h2 class="section-title">Görsel Ekle</h2>
                    </div>

                    <div class="form-group">
                        <div class="form-label">
                            <span class="label-text">Görsel URL</span>
                            <span class="label-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="8" />
                                </svg>
                                Zorunlu
                            </span>
                        </div>
                        <input type="url"
                               class="form-input"
                               asp-for="ImageUrl"
                               id="imageUrlInput"
                               placeholder="https://example.com/image.jpg"
                               required />
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                1920x1080 px veya daha büyük önerilir
                            </div>
                        </div>
                    </div>

                    <div class="image-upload-area" onclick="document.getElementById('imageUrlInput').focus()">
                        <div class="upload-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <p class="upload-text">Görsel URL'sini yukarıya girin</p>
                        <p class="upload-hint">Yüksek kaliteli ve profesyonel görseller kullanın</p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a href="/About/AboutList" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span>İptal</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>Kaydet</span>
                    </button>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="preview-column">
                <div class="preview-wrapper">
                    <div class="preview-content">
                        <div class="preview-label">
                            <span class="preview-label-dot"></span>
                            CANLI ÖNİZLEME
                        </div>
                        <div class="preview-card">
                            <div class="preview-image-container">
                                <img src="" alt="Preview" id="previewImage" />
                                <div class="preview-placeholder" id="previewPlaceholder">
                                    <div class="preview-placeholder-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                    <p class="preview-placeholder-text">Görsel burada görünecek</p>
                                </div>
                            </div>
                            <h3 class="preview-title" id="previewTitle">Başlık Giriniz</h3>
                            <p class="preview-description" id="previewDescription">Açıklama burada görünecek...</p>
                        </div>
                    </div>
                </div>

                <!-- Info Card -->
                <div class="info-card">
                    <div class="info-card-header">
                        <div class="info-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                            </svg>
                        </div>
                        <h4 class="info-card-title">İpuçları</h4>
                    </div>
                    <ul class="info-list">
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            Hikayenizi samimi ve içten anlatın
                        </li>
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            Değerlerinizi ve misyonunuzu vurgulayın
                        </li>
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            Profesyonel ve yüksek çözünürlüklü görsel kullanın
                        </li>
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
