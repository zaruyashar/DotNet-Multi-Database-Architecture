@model List<ResultTestimonialDto>

@{
    ViewData["Title"] = "Müşteri Yorumları Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800;900&family=Raleway:wght@300;400;500;600;700;800&display=swap');

    :root {
        --gold: #D4AF37;
        --gold-dark: #B8941F;
        --gold-light: #F4D03F;
        --navy: #1A1F2E;
        --navy-light: #2D3748;
        --cream: #F9F7F4;
        --white: #FFFFFF;
        --text: #1A1F2E;
        --text-muted: #6B7280;
        --border: #E5E7EB;
        --shadow-sm: 0 2px 12px rgba(212, 175, 55, 0.08);
        --shadow-md: 0 8px 24px rgba(212, 175, 55, 0.12);
        --shadow-lg: 0 16px 48px rgba(212, 175, 55, 0.18);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Raleway', sans-serif;
        background: var(--cream);
        color: var(--text);
    }

    /* Art Deco Background */
    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: 
            repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(212, 175, 55, 0.02) 20px, rgba(212, 175, 55, 0.02) 40px),
            repeating-linear-gradient(-45deg, transparent, transparent 20px, rgba(212, 175, 55, 0.02) 20px, rgba(212, 175, 55, 0.02) 40px);
        z-index: 0;
        pointer-events: none;
    }

    .testimonial-list-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 60px 40px;
        position: relative;
        z-index: 1;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 56px;
        gap: 32px;
        flex-wrap: wrap;
    }

    .header-left {
        flex: 1;
        min-width: 300px;
    }

    .header-ornament {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .ornament-line {
        width: 80px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    .ornament-diamond {
        width: 12px;
        height: 12px;
        background: var(--gold);
        transform: rotate(45deg);
        animation: sparkle 3s ease-in-out infinite;
    }

    @@keyframes sparkle {
        0%, 100% { opacity: 1; transform: rotate(45deg) scale(1); }
        50% { opacity: 0.7; transform: rotate(45deg) scale(1.2); }
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 48px;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 12px;
        letter-spacing: -1px;
        line-height: 1.1;
    }

    .title-accent {
        color: var(--gold);
        font-style: italic;
    }

    .page-subtitle {
        font-size: 16px;
        color: var(--text-muted);
        font-weight: 500;
    }

    .header-actions {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn {
        padding: 16px 32px;
        font-size: 13px;
        font-weight: 700;
        border: 2px solid;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Raleway', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        position: relative;
        overflow: hidden;
    }

    .btn::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        background: rgba(255, 255, 255, 0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn:hover::before {
        width: 300px;
        height: 300px;
    }

    .btn span,
    .btn svg {
        position: relative;
        z-index: 1;
    }

    .btn-primary {
        background: var(--gold);
        color: var(--navy);
        border-color: var(--gold);
        box-shadow: var(--shadow-md);
    }

    .btn-primary:hover {
        background: var(--gold-dark);
        border-color: var(--gold-dark);
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
    }

    .btn-icon {
        background: white;
        color: var(--gold);
        width: 52px;
        height: 52px;
        padding: 0;
        justify-content: center;
        border-color: var(--gold);
    }

    .btn-icon:hover {
        background: var(--gold);
        color: var(--white);
    }

    /* Stats Bar */
    .stats-bar {
        background: var(--navy);
        border: 2px solid var(--gold);
        padding: 40px 48px;
        margin-bottom: 48px;
        position: relative;
        animation: slideUp 0.8s ease-out 0.1s both;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(35px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .stats-bar::before,
    .stats-bar::after {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        border: 2px solid var(--gold);
    }

    .stats-bar::before {
        top: 12px;
        left: 12px;
        border-right: none;
        border-bottom: none;
    }

    .stats-bar::after {
        bottom: 12px;
        right: 12px;
        border-left: none;
        border-top: none;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 40px;
    }

    .stat-item {
        text-align: center;
        padding: 0 20px;
        border-right: 1px solid rgba(212, 175, 55, 0.3);
    }

    .stat-item:last-child {
        border-right: none;
    }

    .stat-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--gold);
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .stat-value {
        font-family: 'Playfair Display', serif;
        font-size: 48px;
        font-weight: 800;
        color: var(--white);
        line-height: 1;
    }

    /* Control Bar */
    .control-bar {
        background: var(--white);
        border: 2px solid var(--border);
        padding: 24px 32px;
        margin-bottom: 40px;
        display: flex;
        gap: 24px;
        align-items: center;
        flex-wrap: wrap;
        position: relative;
        animation: slideUp 0.8s ease-out 0.2s both;
    }

    .control-bar::before,
    .control-bar::after {
        content: '';
        position: absolute;
        width: 16px;
        height: 16px;
        border: 2px solid var(--gold);
    }

    .control-bar::before {
        top: -2px;
        left: -2px;
        border-right: none;
        border-bottom: none;
    }

    .control-bar::after {
        bottom: -2px;
        right: -2px;
        border-left: none;
        border-top: none;
    }

    .search-box {
        flex: 1;
        min-width: 320px;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 14px 20px 14px 48px;
        border: 2px solid var(--border);
        font-size: 15px;
        font-family: 'Raleway', sans-serif;
        font-weight: 600;
        background: var(--cream);
        color: var(--text);
        transition: all 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--gold);
        background: white;
        box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.1);
    }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        color: var(--text-muted);
        pointer-events: none;
    }

    .filter-group {
        display: flex;
        gap: 10px;
    }

    .filter-btn {
        padding: 12px 24px;
        font-size: 12px;
        font-weight: 700;
        border: 2px solid var(--border);
        background: transparent;
        color: var(--text);
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Raleway', sans-serif;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .filter-btn:hover {
        border-color: var(--gold);
        color: var(--gold);
    }

    .filter-btn.active {
        background: var(--gold);
        color: var(--navy);
        border-color: var(--gold);
    }

    /* Testimonials Grid */
    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 36px;
        animation: slideUp 0.8s ease-out 0.3s both;
    }

    .testimonial-card {
        background: var(--white);
        border: 2px solid var(--border);
        padding: 44px;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        animation: fadeInScale 0.6s ease-out both;
    }

    @@keyframes fadeInScale {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }

    .testimonial-card::before,
    .testimonial-card::after {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        border: 2px solid var(--gold);
        opacity: 0;
        transition: opacity 0.5s ease;
    }

    .testimonial-card::before {
        top: -2px;
        left: -2px;
        border-right: none;
        border-bottom: none;
    }

    .testimonial-card::after {
        bottom: -2px;
        right: -2px;
        border-left: none;
        border-top: none;
    }

    .testimonial-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-lg);
        border-color: var(--gold);
    }

    .testimonial-card:hover::before,
    .testimonial-card:hover::after {
        opacity: 1;
    }

    .card-quote {
        width: 40px;
        height: 40px;
        background: var(--gold);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        box-shadow: var(--shadow-sm);
        transition: transform 0.5s ease;
    }

    .testimonial-card:hover .card-quote {
        transform: rotate(360deg);
    }

    .card-quote svg {
        width: 20px;
        height: 20px;
        color: var(--white);
    }

    .card-header {
        text-align: center;
        margin-bottom: 24px;
    }

    .avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        border: 3px solid var(--gold);
        overflow: hidden;
        margin: 0 auto 20px;
        box-shadow: var(--shadow-md);
    }

    .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .customer-name {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 6px;
    }

    .customer-title {
        font-size: 13px;
        color: var(--text-muted);
        font-weight: 600;
        margin-bottom: 16px;
    }

    .rating-stars {
        display: flex;
        justify-content: center;
        gap: 4px;
        margin-bottom: 20px;
    }

    .rating-stars svg {
        width: 18px;
        height: 18px;
        fill: var(--gold);
    }

    .review-text {
        font-size: 15px;
        color: var(--text);
        line-height: 1.8;
        font-style: italic;
        margin-bottom: 24px;
        text-align: center;
        font-weight: 500;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    .meta-info {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        color: var(--text-muted);
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .meta-info svg {
        width: 14px;
        height: 14px;
        color: var(--gold);
    }

    .status-badge {
        padding: 6px 14px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: 2px solid;
    }

    .status-badge.active {
        background: rgba(212, 175, 55, 0.1);
        color: var(--gold);
        border-color: var(--gold);
    }

    .status-badge.inactive {
        background: transparent;
        color: var(--text-muted);
        border-color: var(--border);
    }

    .card-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .action-btn {
        flex: 1;
        padding: 12px 20px;
        font-size: 11px;
        font-weight: 700;
        border: 2px solid;
        background: transparent;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Raleway', sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .action-btn svg {
        width: 14px;
        height: 14px;
    }

    .action-btn.edit {
        color: var(--navy);
        border-color: var(--navy);
    }

    .action-btn.edit:hover {
        background: var(--navy);
        color: white;
    }

    .action-btn.delete {
        color: #EF4444;
        border-color: #EF4444;
    }

    .action-btn.delete:hover {
        background: #EF4444;
        color: white;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 100px 40px;
        background: var(--white);
        border: 2px dashed var(--gold);
        position: relative;
    }

    .empty-state::before,
    .empty-state::after {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        border: 2px solid var(--gold);
    }

    .empty-state::before {
        top: 12px;
        left: 12px;
        border-right: none;
        border-bottom: none;
    }

    .empty-state::after {
        bottom: 12px;
        right: 12px;
        border-left: none;
        border-top: none;
    }

    .empty-icon {
        width: 100px;
        height: 100px;
        margin: 0 auto 28px;
        background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(212, 175, 55, 0.05));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid var(--gold);
    }

    .empty-icon svg {
        width: 50px;
        height: 50px;
        color: var(--gold);
    }

    .empty-title {
        font-family: 'Playfair Display', serif;
        font-size: 36px;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 12px;
    }

    .empty-title span {
        color: var(--gold);
        font-style: italic;
    }

    .empty-text {
        font-size: 16px;
        color: var(--text-muted);
        margin-bottom: 32px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
        font-weight: 500;
    }

    /* Pagination */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        margin-top: 56px;
    }

    .page-btn {
        width: 48px;
        height: 48px;
        border: 2px solid var(--border);
        background: white;
        color: var(--text);
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .page-btn:hover:not(:disabled) {
        border-color: var(--gold);
        color: var(--gold);
    }

    .page-btn.active {
        background: var(--gold);
        color: var(--navy);
        border-color: var(--gold);
        box-shadow: var(--shadow-sm);
    }

    .page-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .testimonials-grid {
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .testimonial-list-container {
            padding: 40px 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: stretch;
        }

        .page-title {
            font-size: 36px;
        }

        .header-actions {
            width: 100%;
        }

        .btn-primary {
            flex: 1;
        }

        .stats-bar {
            padding: 32px 24px;
        }

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .stat-item {
            border-right: none;
            border-bottom: 1px solid rgba(212, 175, 55, 0.3);
            padding: 0 0 20px 0;
        }

        .stat-item:nth-last-child(-n+2) {
            border-bottom: none;
            padding-bottom: 0;
        }

        .control-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            min-width: 100%;
        }

        .testimonials-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 480px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .stat-item {
            padding: 0 0 20px 0;
        }

        .stat-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }
    }
</style>

<div class="testimonial-list-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-left">
            <div class="header-ornament">
                <div class="ornament-line"></div>
                <div class="ornament-diamond"></div>
                <div class="ornament-line"></div>
            </div>
            <h1 class="page-title">
                <span class="title-accent">Müşteri</span> Yorumları
            </h1>
            <p class="page-subtitle">Tüm müşteri değerlendirmelerini görüntüleyin ve yönetin</p>
        </div>
        <div class="header-actions">
            <a href="/Testimonial/CreateTestimonial/" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>Yeni Yorum</span>
            </a>
            <button class="btn btn-icon" title="Yenile" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="22" height="22">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-label">Toplam Yorum</div>
                <div class="stat-value">@Model.Count</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Aktif</div>
                <div class="stat-value">@Model.Count(x => x.Status)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Pasif</div>
                <div class="stat-value">@Model.Count(x => !x.Status)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Ort. Puan</div>
                <div class="stat-value">@(Model.Any() ? Model.Average(x => x.ReviewScore).ToString("0.0") : "0.0")</div>
            </div>
        </div>
    </div>

    <!-- Control Bar -->
    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Müşteri ara..." />
        </div>
        <div class="filter-group">
            <button class="filter-btn active" data-filter="all">Tümü</button>
            <button class="filter-btn" data-filter="active">Aktif</button>
            <button class="filter-btn" data-filter="inactive">Pasif</button>
        </div>
    </div>

    <!-- Testimonials Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="testimonials-grid" id="testimonialsGrid">
            @foreach (var testimonial in Model)
            {
                <div class="testimonial-card" 
                     data-status="@(testimonial.Status ? "active" : "inactive")"
                     data-name="@testimonial.NameSurname.ToLower()">
                    <div class="card-quote">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                        </svg>
                    </div>

                    <div class="card-header">
                        <div class="avatar">
                            <img src="@testimonial.ImageUrl" alt="@testimonial.NameSurname" />
                        </div>
                        <h3 class="customer-name">@testimonial.NameSurname</h3>
                        <p class="customer-title">@testimonial.Title</p>
                        <div class="rating-stars">
                            @for (int i = 0; i < 5; i++)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="opacity: @(i < testimonial.ReviewScore ? "1" : "0.3")">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                            }
                        </div>
                    </div>

                    <p class="review-text">"@testimonial.ReviewDetail"</p>

                    <div class="card-footer">
                        <div class="meta-info">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                            </svg>
                            ID: @testimonial.TestimonialId.Substring(0, 6)
                        </div>
                        <div class="status-badge @(testimonial.Status ? "active" : "inactive")">
                            @(testimonial.Status ? "Aktif" : "Pasif")
                        </div>
                    </div>

                    <div class="card-actions">
                        <a href="/Testimonial/UpdateTestimonial/@testimonial.TestimonialId" class="action-btn edit">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                            Düzenle
                        </a>
                        <a href="/Testimonial/DeleteTestimonial/@testimonial.TestimonialId" 
                           class="action-btn delete" 
                           onclick="return confirm('Bu yorumu silmek istediğinizden emin misiniz?')">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            Sil
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pagination">
            <button class="page-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                </svg>
            </div>
            <h3 class="empty-title">
                Henüz <span>Yorum</span> Yok
            </h3>
            <p class="empty-text">Müşterilerinizin değerli görüşlerini ekleyerek başlayın</p>
            <a href="/Testimonial/CreateTestimonial/" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>İlk Yorumu Ekle</span>
            </a>
        </div>
    }
</div>

<script>
    // Search functionality
    const searchInput = document.getElementById('searchInput');
    const testimonialsGrid = document.getElementById('testimonialsGrid');

    if (searchInput && testimonialsGrid) {
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();
            const cards = testimonialsGrid.querySelectorAll('.testimonial-card');

            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                card.style.display = name.includes(searchTerm) ? '' : 'none';
            });
        });
    }

    // Filter functionality
    const filterButtons = document.querySelectorAll('.filter-btn');
    
    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            filterButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            const filter = btn.getAttribute('data-filter');
            const cards = document.querySelectorAll('.testimonial-card');

            cards.forEach(card => {
                const status = card.getAttribute('data-status');
                
                if (filter === 'all') {
                    card.style.display = '';
                } else {
                    card.style.display = status === filter ? '' : 'none';
                }
            });
        });
    });

    // Stagger animation for cards
    const testimonialCards = document.querySelectorAll('.testimonial-card');
    testimonialCards.forEach((card, index) => {
        card.style.animationDelay = `${0.4 + (index * 0.05)}s`;
    });
</script>
